# Copy this file to `.env` and fill in values.

# Firebase Configuration (required for auth + storage)
VITE_FIREBASE_API_KEY=PASTE_KEY
VITE_FIREBASE_AUTH_DOMAIN=PASTE_DOMAIN
VITE_FIREBASE_DB_URL=PASTE_URL
VITE_FIREBASE_PROJECT_ID=PASTE_ID
VITE_FIREBASE_STORAGE_BUCKET=PASTE_BUCKET
VITE_FIREBASE_SENDER_ID=PASTE_ID
VITE_FIREBASE_APP_ID=PASTE_ID
VITE_FIREBASE_MEASUREMENT_ID=PASTE_ID

# YouTube Data API Keys (optional; trending/search falls back to demo tracks without keys)
VITE_YT_KEY_1=PASTE_KEY
VITE_YT_KEY_2=
VITE_YT_KEY_3=
VITE_YT_KEY_4=
VITE_YT_KEY_5=

# AI Configuration
# Groq (OpenAI-compatible) - used for "Create Song"
VITE_GROQ_API_KEY=PASTE_KEY

# Optional overrides (defaults shown)
VITE_AI_BASE_URL=https://api.groq.com/openai/v1
VITE_AI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional fallback for playlist recommendations
VITE_GEMINI_API_KEY=

